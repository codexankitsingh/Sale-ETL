{"timestamp":"2026-03-18T07:08:44.863425Z","level":"info","event":"Executing: {'query': {'query': 'MERGE `sale-etl.sales_raw.customers` T\\nUSING (\\n    SELECT customer_trx_id, subscriber_id, subscribe_date, first_order_date, customer_postal_code, customer_city, customer_country, customer_country_code, age, gender, etl_timestamp\\n    FROM (\\n        SELECT *,\\n               ROW_NUMBER() OVER (\\n                   PARTITION BY customer_trx_id\\n                   ORDER BY etl_timestamp DESC\\n               ) AS _rn\\n        FROM `sale-etl.sales_raw.customers_staging`\\n    )\\n    WHERE _rn = 1\\n) S\\nON T.customer_trx_id = S.customer_trx_id\\nWHEN MATCHED THEN\\n    UPDATE SET\\n        T.subscriber_id = S.subscriber_id,\\n        T.subscribe_date = S.subscribe_date,\\n        T.first_order_date = S.first_order_date,\\n        T.customer_postal_code = S.customer_postal_code,\\n        T.customer_city = S.customer_city,\\n        T.customer_country = S.customer_country,\\n        T.customer_country_code = S.customer_country_code,\\n        T.age = S.age,\\n        T.gender = S.gender,\\n        T.etl_timestamp = S.etl_timestamp\\nWHEN NOT MATCHED THEN\\n    INSERT (customer_trx_id, subscriber_id, subscribe_date, first_order_date, customer_postal_code, customer_city, customer_country, customer_country_code, age, gender, etl_timestamp)\\n    VALUES (S.customer_trx_id, S.subscriber_id, S.subscribe_date, S.first_order_date, S.customer_postal_code, S.customer_city, S.customer_country, S.customer_country_code, S.age, S.gender, S.etl_timestamp)', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
