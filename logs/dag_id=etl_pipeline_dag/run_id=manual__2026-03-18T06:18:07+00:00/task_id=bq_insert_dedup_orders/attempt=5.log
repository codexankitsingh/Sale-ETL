{"timestamp":"2026-03-18T07:28:54.056054Z","level":"info","event":"Executing: {'query': {'query': 'INSERT INTO `sale-etl.sales_raw.orders`\\n    (order_id, customer_trx_id, order_status, order_purchase_timestamp, order_approved_at, order_delivered_carrier_date, order_delivered_customer_date, order_estimated_delivery_date, sale_date, etl_timestamp)\\nSELECT\\n    order_id,\\n    customer_trx_id,\\n    order_status,\\n    order_purchase_timestamp,\\n    order_approved_at,\\n    order_delivered_carrier_date,\\n    order_delivered_customer_date,\\n    order_estimated_delivery_date,\\n    CAST(sale_date AS DATE) AS sale_date,\\n    etl_timestamp\\nFROM (\\n    SELECT\\n        s.order_id,\\n                s.customer_trx_id,\\n                s.order_status,\\n                s.order_purchase_timestamp,\\n                s.order_approved_at,\\n                s.order_delivered_carrier_date,\\n                s.order_delivered_customer_date,\\n                s.order_estimated_delivery_date,\\n                s.etl_timestamp,\\n        DATE(s.order_purchase_timestamp)            AS sale_date,\\n        ROW_NUMBER() OVER (\\n            PARTITION BY s.order_id\\n            ORDER BY s.etl_timestamp DESC\\n        )                           AS _rn\\n    FROM `sale-etl.sales_raw.orders_staging` s\\n    \\n)\\nWHERE _rn = 1', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
