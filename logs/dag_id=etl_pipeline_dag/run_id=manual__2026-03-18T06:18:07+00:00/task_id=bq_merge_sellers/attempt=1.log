{"timestamp":"2026-03-18T07:08:45.066486Z","level":"info","event":"Executing: {'query': {'query': 'MERGE `sale-etl.sales_raw.sellers` T\\nUSING (\\n    SELECT seller_id, seller_name, seller_postal_code, seller_city, country_code, seller_country, etl_timestamp\\n    FROM (\\n        SELECT *,\\n               ROW_NUMBER() OVER (\\n                   PARTITION BY seller_id\\n                   ORDER BY etl_timestamp DESC\\n               ) AS _rn\\n        FROM `sale-etl.sales_raw.sellers_staging`\\n    )\\n    WHERE _rn = 1\\n) S\\nON T.seller_id = S.seller_id\\nWHEN MATCHED THEN\\n    UPDATE SET\\n        T.seller_name = S.seller_name,\\n        T.seller_postal_code = S.seller_postal_code,\\n        T.seller_city = S.seller_city,\\n        T.country_code = S.country_code,\\n        T.seller_country = S.seller_country,\\n        T.etl_timestamp = S.etl_timestamp\\nWHEN NOT MATCHED THEN\\n    INSERT (seller_id, seller_name, seller_postal_code, seller_city, country_code, seller_country, etl_timestamp)\\n    VALUES (S.seller_id, S.seller_name, S.seller_postal_code, S.seller_city, S.country_code, S.seller_country, S.etl_timestamp)', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
