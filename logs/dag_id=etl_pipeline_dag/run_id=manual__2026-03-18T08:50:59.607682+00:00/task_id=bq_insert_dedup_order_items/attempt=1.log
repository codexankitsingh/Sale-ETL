{"timestamp":"2026-03-18T09:04:13.120720Z","level":"info","event":"Executing: {'query': {'query': 'INSERT INTO `sale-etl.sales_raw.order_items`\\n    (order_id, order_item_id, product_id, seller_id, shipping_limit_date, price, freight_value, total_item_value, sale_date, etl_timestamp)\\nSELECT\\n    order_id,\\n    order_item_id,\\n    product_id,\\n    seller_id,\\n    shipping_limit_date,\\n    price,\\n    freight_value,\\n    total_item_value,\\n    CAST(sale_date AS DATE) AS sale_date,\\n    etl_timestamp\\nFROM (\\n    SELECT\\n        s.order_id,\\n                s.order_item_id,\\n                s.product_id,\\n                s.seller_id,\\n                s.shipping_limit_date,\\n                s.price,\\n                s.freight_value,\\n                s.total_item_value,\\n                s.etl_timestamp,\\n        DATE(o.order_purchase_timestamp)            AS sale_date,\\n        ROW_NUMBER() OVER (\\n            PARTITION BY s.order_id, s.order_item_id\\n            ORDER BY s.etl_timestamp DESC\\n        )                           AS _rn\\n    FROM `sale-etl.sales_raw.order_items_staging` s\\n    LEFT JOIN `sale-etl.sales_raw.orders` o\\n                ON s.order_id = o.order_id\\n)\\nWHERE _rn = 1', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
