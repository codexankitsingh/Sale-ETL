{"timestamp":"2026-03-18T09:03:52.385630Z","level":"info","event":"Executing: {'query': {'query': 'MERGE `sale-etl.sales_raw.geolocations` T\\nUSING (\\n    SELECT geo_postal_code, geo_lat, geo_lon, geolocation_city, geo_country, etl_timestamp\\n    FROM (\\n        SELECT *,\\n               ROW_NUMBER() OVER (\\n                   PARTITION BY geo_postal_code\\n                   ORDER BY etl_timestamp DESC\\n               ) AS _rn\\n        FROM `sale-etl.sales_raw.geolocations_staging`\\n    )\\n    WHERE _rn = 1\\n) S\\nON T.geo_postal_code = S.geo_postal_code\\nWHEN MATCHED THEN\\n    UPDATE SET\\n        T.geo_lat = S.geo_lat,\\n        T.geo_lon = S.geo_lon,\\n        T.geolocation_city = S.geolocation_city,\\n        T.geo_country = S.geo_country,\\n        T.etl_timestamp = S.etl_timestamp\\nWHEN NOT MATCHED THEN\\n    INSERT (geo_postal_code, geo_lat, geo_lon, geolocation_city, geo_country, etl_timestamp)\\n    VALUES (S.geo_postal_code, S.geo_lat, S.geo_lon, S.geolocation_city, S.geo_country, S.etl_timestamp)', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
