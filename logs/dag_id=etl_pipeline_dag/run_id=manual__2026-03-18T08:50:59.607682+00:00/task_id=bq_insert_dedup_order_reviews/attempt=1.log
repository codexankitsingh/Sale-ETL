{"timestamp":"2026-03-18T09:04:12.886128Z","level":"info","event":"Executing: {'query': {'query': 'INSERT INTO `sale-etl.sales_raw.order_reviews`\\n    (review_id, order_id, review_score, review_comment_title_en, review_comment_message_en, review_creation_date, review_answer_timestamp, review_sentiment, sale_date, etl_timestamp)\\nSELECT\\n    review_id,\\n    order_id,\\n    review_score,\\n    review_comment_title_en,\\n    review_comment_message_en,\\n    review_creation_date,\\n    review_answer_timestamp,\\n    review_sentiment,\\n    CAST(sale_date AS DATE) AS sale_date,\\n    etl_timestamp\\nFROM (\\n    SELECT\\n        s.review_id,\\n                s.order_id,\\n                s.review_score,\\n                s.review_comment_title_en,\\n                s.review_comment_message_en,\\n                s.review_creation_date,\\n                s.review_answer_timestamp,\\n                s.review_sentiment,\\n                s.etl_timestamp,\\n        DATE(o.order_purchase_timestamp)            AS sale_date,\\n        ROW_NUMBER() OVER (\\n            PARTITION BY s.review_id\\n            ORDER BY s.etl_timestamp DESC\\n        )                           AS _rn\\n    FROM `sale-etl.sales_raw.order_reviews_staging` s\\n    LEFT JOIN `sale-etl.sales_raw.orders` o\\n                ON s.order_id = o.order_id\\n)\\nWHERE _rn = 1', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
