{"timestamp":"2026-03-18T09:03:58.587054Z","level":"info","event":"Executing: {'query': {'query': 'MERGE `sale-etl.sales_raw.products` T\\nUSING (\\n    SELECT product_id, product_category_name, product_weight_gr, product_length_cm, product_height_cm, product_width_cm, product_volume_cm3, etl_timestamp\\n    FROM (\\n        SELECT *,\\n               ROW_NUMBER() OVER (\\n                   PARTITION BY product_id\\n                   ORDER BY etl_timestamp DESC\\n               ) AS _rn\\n        FROM `sale-etl.sales_raw.products_staging`\\n    )\\n    WHERE _rn = 1\\n) S\\nON T.product_id = S.product_id\\nWHEN MATCHED THEN\\n    UPDATE SET\\n        T.product_category_name = S.product_category_name,\\n        T.product_weight_gr = S.product_weight_gr,\\n        T.product_length_cm = S.product_length_cm,\\n        T.product_height_cm = S.product_height_cm,\\n        T.product_width_cm = S.product_width_cm,\\n        T.product_volume_cm3 = S.product_volume_cm3,\\n        T.etl_timestamp = S.etl_timestamp\\nWHEN NOT MATCHED THEN\\n    INSERT (product_id, product_category_name, product_weight_gr, product_length_cm, product_height_cm, product_width_cm, product_volume_cm3, etl_timestamp)\\n    VALUES (S.product_id, S.product_category_name, S.product_weight_gr, S.product_length_cm, S.product_height_cm, S.product_width_cm, S.product_volume_cm3, S.etl_timestamp)', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
