{"timestamp":"2026-03-18T09:04:10.799432Z","level":"info","event":"Executing: {'query': {'query': 'INSERT INTO `sale-etl.sales_raw.order_payments`\\n    (order_id, payment_sequential, payment_type, payment_installments, payment_value, sale_date, etl_timestamp)\\nSELECT\\n    order_id,\\n    payment_sequential,\\n    payment_type,\\n    payment_installments,\\n    payment_value,\\n    CAST(sale_date AS DATE) AS sale_date,\\n    etl_timestamp\\nFROM (\\n    SELECT\\n        s.order_id,\\n                s.payment_sequential,\\n                s.payment_type,\\n                s.payment_installments,\\n                s.payment_value,\\n                s.etl_timestamp,\\n        DATE(o.order_purchase_timestamp)            AS sale_date,\\n        ROW_NUMBER() OVER (\\n            PARTITION BY s.order_id, s.payment_sequential\\n            ORDER BY s.etl_timestamp DESC\\n        )                           AS _rn\\n    FROM `sale-etl.sales_raw.order_payments_staging` s\\n    LEFT JOIN `sale-etl.sales_raw.orders` o\\n                ON s.order_id = o.order_id\\n)\\nWHERE _rn = 1', 'useLegacySql': False}}'","logger":"airflow.task.operators.airflow.providers.google.cloud.operators.bigquery.BigQueryInsertJobOperator","filename":"bigquery.py","lineno":2404}
