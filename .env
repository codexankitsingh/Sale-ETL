AIRFLOW_UID=50000


# ── GCP PROJECT ────────────────────────────────────────────
GCP_PROJECT_ID=sale-etl
GCP_REGION=us-east1
GCP_ZONE=us-east1-b


# ── GCS BUCKETS ────────────────────────────────────────────
GCS_SOURCE_BUCKET=sale-etl-source-bucket
GCS_MAIN_BUCKET=sale-etl-main-bucket


# ── BIGQUERY ───────────────────────────────────────────────
BIGQUERY_DATASET_RAW=sales_raw
BIGQUERY_DATASET_ANALYTICS=sales_analytics
BIGQUERY_LOCATION=US


# ── DATAPROC ───────────────────────────────────────────────
DATAPROC_CLUSTER_NAME=sale-etl-spark-cluster
DATAPROC_REGION=us-east1
DATAPROC_NUM_WORKERS=0
DATAPROC_MASTER_MACHINE_TYPE=e2-standard-4
DATAPROC_WORKER_MACHINE_TYPE=e2-standard-4
DATAPROC_IMAGE_VERSION=2.1-debian11


# ── GCP CREDENTIALS (path INSIDE the container) ────────────
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/config/gcp_credentials.json


# ── AIRFLOW CORE ───────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=4cLp6yYqg8lDnKlMfSRYr1L1GjlHy1BAc6zYYVqTKT8=


# ── AIRFLOW DATABASE ───────────────────────────────────────
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow


# ── AIRFLOW WEBSERVER ──────────────────────────────────────
AIRFLOW__WEBSERVER__SECRET_KEY=759b8b809b453f1a0dbf61374a6ddbf2a1281dcbc570f820d04b33384b2298bb

# ── AIRFLOW DAG PARSING ────────────────────────────────────
AIRFLOW__CORE__DAGBAG_IMPORT_TIMEOUT=120

# ── AIRFLOW GCP CONNECTION ─────────────────────────────────
AIRFLOW_CONN_GOOGLE_CLOUD_DEFAULT=google-cloud-platform://?extra__google_cloud_platform__key_path=%2Fopt%2Fairflow%2Fconfig%2Fgcp_credentials.json&extra__google_cloud_platform__project=sale-etl&extra__google_cloud_platform__scope=https%3A%2F%2Fwww.googleapis.com%2Fauth%2Fcloud-platform


# ── AIRFLOW VARIABLES ──────────────────────────────────────
AIRFLOW_VAR_GCP_PROJECT_ID=sale-etl
AIRFLOW_VAR_GCS_SOURCE_BUCKET=sale-etl-source-bucket
AIRFLOW_VAR_GCS_MAIN_BUCKET=sale-etl-main-bucket
AIRFLOW_VAR_DATAPROC_CLUSTER_NAME=sale-etl-spark-cluster
AIRFLOW_VAR_DATAPROC_REGION=us-east1
AIRFLOW_VAR_BQ_RAW_DATASET=sales_raw
AIRFLOW_VAR_BQ_ANALYTICS_DATASET=sales_analytics


# ── POSTGRES ───────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow


# ── AIRFLOW ADMIN ──────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
